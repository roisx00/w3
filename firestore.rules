rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Talent / Resume profiles ─────────────────────────────────────────────
    // Public read. Admin SDK (server-side API routes) bypasses these rules for
    // badge grants etc. Client writes go through standard auth.
    match /talents/{userId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && (request.auth.uid == userId || isAdmin());
      allow delete: if request.auth != null
        && (request.auth.uid == userId || isAdmin());

      // Peer reviews — reviewer can only write their own entry, not on themselves
      match /reviews/{reviewerId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.auth.uid == reviewerId
          && request.auth.uid != userId;
        allow update: if request.auth != null
          && request.auth.uid == reviewerId;
        allow delete: if request.auth != null
          && (request.auth.uid == reviewerId || isAdmin());
      }
    }

    // ─── KOL profiles ─────────────────────────────────────────────────────────
    // Badge grants & saves go via /api/kols/save (Admin SDK) — bypasses rules.
    match /kols/{kolId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && (request.auth.uid == kolId || isAdmin());
      allow delete: if request.auth != null
        && (request.auth.uid == kolId || isAdmin());

      // On-chain feedback left by badge-holding projects/users
      match /reviews/{reviewerId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.auth.uid == reviewerId
          && request.auth.uid != kolId
          && get(/databases/$(database)/documents/talents/$(request.auth.uid)).data.hasBadge == true;
        allow update: if request.auth != null
          && request.auth.uid == reviewerId;
        allow delete: if request.auth != null
          && (request.auth.uid == reviewerId || isAdmin());
      }
    }

    // ─── Job listings ─────────────────────────────────────────────────────────
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && (resource.data.postedBy == request.auth.uid || isAdmin());
      allow delete: if request.auth != null
        && (resource.data.postedBy == request.auth.uid || isAdmin());
    }

    // ─── Airdrop listings ─────────────────────────────────────────────────────
    match /airdrops/{airdropId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && (resource.data.submittedBy == request.auth.uid || isAdmin());
      allow delete: if request.auth != null
        && (resource.data.submittedBy == request.auth.uid || isAdmin());
    }

    // ─── Payments ─────────────────────────────────────────────────────────────
    match /payments/{paymentId} {
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isAdmin();
    }

    // ─── Job applications ─────────────────────────────────────────────────────
    match /applications/{appId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.applicantId
            || request.auth.uid == resource.data.posterId
            || isAdmin());
      allow create: if request.auth != null
        && request.resource.data.applicantId == request.auth.uid;
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.applicantId || isAdmin());
    }

    // ─── Referrals ────────────────────────────────────────────────────────────
    match /referrals/{refId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.referrerId
            || request.auth.uid == resource.data.referredId
            || isAdmin());
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isAdmin();
    }

    // ─── Conversations (DM threads) ───────────────────────────────────────────
    match /conversations/{convoId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants;
      allow delete: if request.auth != null && isAdmin();

      match /messages/{messageId} {
        allow read: if request.auth != null
          && request.auth.uid in
             get(/databases/$(database)/documents/conversations/$(convoId)).data.participants;
        allow create: if request.auth != null
          && request.resource.data.senderId == request.auth.uid;
        // No update or delete on messages — immutable once sent
        allow update, delete: if false;
      }
    }

    // ─── User private settings ────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // ─── Counters (badge promo slots, etc.) ───────────────────────────────────
    match /counters/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── KOL Proposals (Hire-a-KOL form submissions) ──────────────────────────
    // Anyone can submit a proposal (no auth required — contact form).
    // Only admin can read proposals (they contain private contact info).
    match /kol_proposals/{proposalId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ─── Mint Bot ─────────────────────────────────────────────────────────────
    match /mint_bot_wallets/{docId} {
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    match /mint_bot_jobs/{docId} {
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    match /mint_bot_logs/{docId} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow write: if false;
    }
    // ─────────────────────────────────────────────────────────────────────────

    // ─── Admin check ──────────────────────────────────────────────────────────
    // Primary: Privy DID (owner account)
    // Secondary: email token claim
    // Tertiary: isAdmin: true field on talent doc (for multi-admin support)
    function isAdmin() {
      return request.auth != null
        && (request.auth.uid == 'cmmutno61018m0dlb7p754q7c'
            || request.auth.token.email == 'roisx00@gmail.com'
            || get(/databases/$(database)/documents/talents/$(request.auth.uid)).data.isAdmin == true);
    }
  }
}
