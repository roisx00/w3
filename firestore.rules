rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Talent / Resume profiles ─────────────────────────────────────────────
    // All writes from the app go through Admin SDK (server API routes) which
    // bypasses these rules. Client-side writes are not used with Privy auth.
    match /talents/{userId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && (request.auth.uid == userId || isAdmin());
      allow delete: if request.auth != null
        && (request.auth.uid == userId || isAdmin());

      match /reviews/{reviewerId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.auth.uid == reviewerId
          && request.auth.uid != userId;
        allow update: if request.auth != null
          && request.auth.uid == reviewerId;
        allow delete: if request.auth != null
          && (request.auth.uid == reviewerId || isAdmin());
      }
    }

    // ─── KOL profiles ─────────────────────────────────────────────────────────
    match /kols/{kolId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && (request.auth.uid == kolId || isAdmin());
      allow delete: if request.auth != null
        && (request.auth.uid == kolId || isAdmin());

      match /reviews/{reviewerId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.auth.uid == reviewerId
          && request.auth.uid != kolId
          && get(/databases/$(database)/documents/talents/$(request.auth.uid)).data.hasBadge == true;
        allow update: if request.auth != null
          && request.auth.uid == reviewerId;
        allow delete: if request.auth != null
          && (request.auth.uid == reviewerId || isAdmin());
      }
    }

    // ─── Job listings ─────────────────────────────────────────────────────────
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && (resource.data.postedBy == request.auth.uid || isAdmin());
      allow delete: if request.auth != null
        && (resource.data.postedBy == request.auth.uid || isAdmin());
    }

    // ─── Airdrop listings ─────────────────────────────────────────────────────
    match /airdrops/{airdropId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && (resource.data.submittedBy == request.auth.uid || isAdmin());
      allow delete: if request.auth != null
        && (resource.data.submittedBy == request.auth.uid || isAdmin());
    }

    // ─── Payments ─────────────────────────────────────────────────────────────
    // All payment reads/writes go through Admin SDK (server API routes).
    match /payments/{paymentId} {
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isAdmin();
    }

    // ─── Job applications ─────────────────────────────────────────────────────
    // Public read needed for applicant counts on job cards (no Firebase Auth
    // with Privy). Writes still require auth.
    match /applications/{appId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.applicantId == request.auth.uid;
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.applicantId || isAdmin());
    }

    // ─── Referrals ────────────────────────────────────────────────────────────
    match /referrals/{refId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.referrerId
            || request.auth.uid == resource.data.referredId
            || isAdmin());
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isAdmin();
    }

    // ─── Conversations (DM threads) ───────────────────────────────────────────
    match /conversations/{convoId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants;
      allow delete: if request.auth != null && isAdmin();

      match /messages/{messageId} {
        allow read: if request.auth != null
          && request.auth.uid in
             get(/databases/$(database)/documents/conversations/$(convoId)).data.participants;
        allow create: if request.auth != null
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ─── User private settings ────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // ─── Counters (badge promo slots, etc.) ───────────────────────────────────
    match /counters/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── KOL Proposals ────────────────────────────────────────────────────────
    // Anyone can submit (contact form). Admin reads via Admin SDK.
    match /kol_proposals/{proposalId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ─── Mint Bot ─────────────────────────────────────────────────────────────
    match /mint_bot_wallets/{docId} {
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    match /mint_bot_jobs/{docId} {
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    match /mint_bot_logs/{docId} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow write: if false;
    }

    // ─── Admin check ──────────────────────────────────────────────────────────
    // NOTE: Since the app uses Privy (not Firebase Auth), request.auth is null
    // for all client-side calls. Admin operations go through server API routes
    // using Firebase Admin SDK which bypasses these rules entirely.
    function isAdmin() {
      return request.auth != null
        && (request.auth.uid == 'cmmutno61018m0dlb7p754q7c'
            || request.auth.token.email == 'roisx00@gmail.com'
            || get(/databases/$(database)/documents/talents/$(request.auth.uid)).data.isAdmin == true);
    }
  }
}
