rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Talents ──────────────────────────────────────────────────────────────
    // Anyone can read talent profiles (public directory)
    // Only the authenticated owner can write their own profile
    match /talents/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null
        && (request.auth.uid == userId || isAdmin());

      // Reviews subcollection
      match /reviews/{reviewerId} {
        allow read: if true;
        // Doc ID = reviewerId, so a user can only write their own review
        // Cannot review yourself
        allow create: if request.auth != null
          && request.auth.uid == reviewerId
          && request.auth.uid != userId;
        allow update: if request.auth != null
          && request.auth.uid == reviewerId;
        allow delete: if request.auth != null
          && (request.auth.uid == reviewerId || isAdmin());
      }
    }

    // ─── Jobs ─────────────────────────────────────────────────────────────────
    // Anyone can read job postings
    // Authenticated users can create; only the poster or admin can delete
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.postedBy == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.postedBy == request.auth.uid || isAdmin());
      allow delete: if request.auth != null
        && (resource.data.postedBy == request.auth.uid || isAdmin());
    }

    // ─── Airdrops ─────────────────────────────────────────────────────────────
    // Anyone can read airdrops
    // Authenticated users can submit; only submitter or admin can delete
    match /airdrops/{airdropId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && (resource.data.submittedBy == request.auth.uid || isAdmin());
      allow delete: if request.auth != null
        && (resource.data.submittedBy == request.auth.uid || isAdmin());
    }

    // ─── Referrals ────────────────────────────────────────────────────────────
    match /referrals/{refId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.referrerId || isAdmin());
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isAdmin();
    }

    // ─── Applications ─────────────────────────────────────────────────────────
    match /applications/{appId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.applicantId
            || request.auth.uid == resource.data.posterId
            || isAdmin());
      allow create: if request.auth != null
        && request.resource.data.applicantId == request.auth.uid;
      allow delete: if request.auth != null && isAdmin();
    }

    // ─── Payments ─────────────────────────────────────────────────────────────
    match /payments/{paymentId} {
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isAdmin();
    }

    // ─── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // ─── Helper: Admin check ──────────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null
        && (request.auth.uid == '8QlMg7xGGrWeJKW6WnEUF5OQUb53'
            || request.auth.token.email == 'roisx00@gmail.com');
    }
  }
}
