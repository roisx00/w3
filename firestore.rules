rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Talents ──────────────────────────────────────────────────────────────
    // Anyone can read talent profiles (public directory)
    // Only the authenticated owner can write their own profile
    match /talents/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null
        && (request.auth.uid == userId || isAdmin());
    }

    // ─── Jobs ─────────────────────────────────────────────────────────────────
    // Anyone can read job postings
    // Authenticated users can create; only the poster or admin can delete
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.postedBy == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.postedBy == request.auth.uid || isAdmin());
      allow delete: if request.auth != null
        && (resource.data.postedBy == request.auth.uid || isAdmin());
    }

    // ─── Airdrops ─────────────────────────────────────────────────────────────
    // Anyone can read airdrops
    // Authenticated users can submit; only submitter or admin can delete
    match /airdrops/{airdropId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.submittedBy == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.submittedBy == request.auth.uid || isAdmin());
      allow delete: if request.auth != null
        && (resource.data.submittedBy == request.auth.uid || isAdmin());
    }

    // ─── Helper: Admin check ──────────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/talents/$(request.auth.uid)).data.isAdmin == true;
    }
  }
}
